generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL_LOCAL")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id               String           @id @default(uuid()) @db.Uuid
  email            String           @unique
  fullName         String?          @map("full_name")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  avatars          Avatar[]
  aiJobs           AiJob[]
  generatedScenes  GeneratedScene[]
  userSavedDresses UserSavedDress[]

  @@map("users")
}

model Avatar {
  id            String           @id @default(uuid()) @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  glbUrl        String           @map("glb_url")
  frontPhotoUrl String?          @map("front_photo_url")
  sidePhotoUrl  String?          @map("side_photo_url")
  backPhotoUrl  String?          @map("back_photo_url")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes        GeneratedScene[]

  @@map("avatars")
}

model Dress {
  id               String           @id @default(uuid()) @db.Uuid
  title            String
  brand            String?
  source           String?
  productUrl       String           @map("product_url")
  imageUrl         String?          @map("image_url")
  price            Decimal?         @db.Decimal(10, 2)
  currency         String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  generatedScenes  GeneratedScene[]
  userSavedDresses UserSavedDress[]

  @@map("dresses")
}

model UserSavedDress {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  dressId   String   @map("dress_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dress     Dress    @relation(fields: [dressId], references: [id], onDelete: Cascade)

  @@unique([userId, dressId])
  @@map("user_saved_dresses")
}

model AiJob {
  id              String           @id @db.Uuid
  userId          String?          @map("user_id") @db.Uuid
  jobType         String           @map("job_type")
  status          JobStatus
  payload         Json
  resultUrl       String?          @map("result_url")
  error           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  completedAt     DateTime?        @map("completed_at")
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  generatedScenes GeneratedScene[]

  @@map("ai_jobs")
}

model GeneratedScene {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  jobId       String   @map("job_id") @db.Uuid
  avatarId    String?  @map("avatar_id") @db.Uuid
  dressId     String?  @map("dress_id") @db.Uuid
  scenePrompt String?  @map("scene_prompt")
  resultUrl   String   @map("result_url")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job         AiJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  avatar      Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)
  dress       Dress?   @relation(fields: [dressId], references: [id], onDelete: SetNull)

  @@map("generated_scenes")
}
