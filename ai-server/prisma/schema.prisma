datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client_py {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String    @unique @db.VarChar(255)
  passwordHash      String?   @map("password_hash") @db.VarChar(255)
  name              String    @map("name") @db.VarChar(255)
  avatarUrl         String?   @map("avatar_url") @db.Text
  verificationToken String?   @map("verification_token") @db.VarChar(255)
  emailVerified     Boolean   @default(false) @map("email_verified")
  isActive          Boolean   @default(true) @map("is_active")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp
  deletedAt         DateTime? @map("deleted_at") @db.Timestamp

  // OAuth fields
  oauthProvider String? @map("oauth_provider") @db.VarChar(50)
  oauthId       String? @map("oauth_id") @db.VarChar(255)

  // Relations
  preferences       UserPreferences?
  bodyImages        UserBodyImage[]
  events            Event[]
  garments          Garment[]
  outfits           Outfit[]
  tryonResults      TryonResult[]
  processingJobs    ProcessingJob[]
  recommendationLog RecommendationLog[]
  refreshTokens     RefreshToken[]
  dressSearches     DressSearch[]
  generationJobs    GenerationJob[]
  consentRecords    ConsentRecord[]
  userProfile       UserProfile?

  @@index([email])
  @@index([oauthProvider, oauthId])
  @@map("users")
}

model UserPreferences {
  userId            String   @id @map("user_id") @db.Uuid
  preferredColors   Json?    @map("preferred_colors")
  styleTags         Json?    @map("style_tags")
  sizeProfile       Json?    @map("size_profile")
  bodyMeasurements  Json?    @map("body_measurements")
  notificationPrefs Json?    @default("{}") @map("notification_prefs")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamp

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model UserBodyImage {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  imageUrl     String    @map("image_url") @db.Text
  thumbnailUrl String?   @map("thumbnail_url") @db.Text
  poseData     Json?     @map("pose_data")
  isDefault    Boolean   @default(false) @map("is_default")
  metadata     Json?
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamp
  deletedAt    DateTime? @map("deleted_at") @db.Timestamp

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryonResults TryonResult[]

  @@index([userId, isDefault])
  @@index([userId, createdAt(sort: Desc)])
  @@map("user_body_images")
}

model RefreshToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique @db.Text
  sessionId String   @unique @map("session_id") @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  expiresAt DateTime @map("expires_at") @db.Timestamp
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionId])
  @@map("refresh_tokens")
}

model Event {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  name           String    @db.VarChar(255)
  eventType      String?   @map("event_type") @db.VarChar(50)
  date           DateTime? @db.Date
  location       String?   @db.VarChar(255)
  weatherContext Json?     @map("weather_context")
  notes          String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamp
  deletedAt      DateTime? @map("deleted_at") @db.Timestamp

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfits           Outfit[]
  recommendationLog RecommendationLog[]

  @@index([userId, date])
  @@index([eventType])
  @@map("events")
}

model Garment {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String? @map("user_id") @db.Uuid
  name              String  @db.VarChar(255)
  category          String  @db.VarChar(50)
  subCategory       String? @map("sub_category") @db.VarChar(50)
  brand             String? @db.VarChar(100)
  colorTags         Json?   @default("[]") @map("color_tags")
  styleTags         Json?   @default("[]") @map("style_tags")
  seasonTags        Json?   @default("[]") @map("season_tags")
  imageUrl          String  @map("image_url") @db.Text
  thumbnailUrl      String? @map("thumbnail_url") @db.Text
  processedImageUrl String? @map("processed_image_url") @db.Text
  model3dUrl        String? @map("model_3d_url") @db.Text
  metadata          Json?   @default("{}")
  isPublic          Boolean   @default(false) @map("is_public")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamp
  deletedAt         DateTime? @map("deleted_at") @db.Timestamp

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  outfitItems OutfitItem[]

  @@index([userId, category])
  @@index([category, isPublic])
  @@index([createdAt(sort: Desc)])
  @@map("garments")
}

model Outfit {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  name            String?   @db.VarChar(255)
  description     String?   @db.Text
  eventId         String?   @map("event_id") @db.Uuid
  previewImageUrl String?   @map("preview_image_url") @db.Text
  isFavorite      Boolean   @default(false) @map("is_favorite")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamp
  deletedAt       DateTime? @map("deleted_at") @db.Timestamp

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  outfitItems  OutfitItem[]
  tryonResults TryonResult[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, eventId])
  @@index([userId, isFavorite])
  @@map("outfits")
}

model OutfitItem {
  outfitId   String @map("outfit_id") @db.Uuid
  garmentId  String @map("garment_id") @db.Uuid
  layerOrder Int    @map("layer_order") @db.Integer
  metadata   Json?  @default("{}")

  outfit  Outfit  @relation(fields: [outfitId], references: [id], onDelete: Cascade)
  garment Garment @relation(fields: [garmentId], references: [id], onDelete: Cascade)

  @@id([outfitId, garmentId])
  @@index([outfitId, layerOrder])
  @@map("outfit_items")
}

model TryonResult {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String  @map("user_id") @db.Uuid
  bodyImageId String  @map("body_image_id") @db.Uuid
  outfitId    String? @map("outfit_id") @db.Uuid

  resultImageUrl   String  @map("result_image_url") @db.Text
  thumbnailUrl     String? @map("thumbnail_url") @db.Text
  generationParams Json?   @map("generation_params")
  processingTimeMs Int?    @map("processing_time_ms") @db.Integer
  modelVersion     String? @map("model_version") @db.VarChar(50)
  isFavorite       Boolean @default(false) @map("is_favorite")
  viewCount        Int     @default(0) @map("view_count") @db.Integer

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp
  deletedAt DateTime? @map("deleted_at") @db.Timestamp

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bodyImage UserBodyImage @relation(fields: [bodyImageId], references: [id], onDelete: Cascade)
  outfit    Outfit?       @relation(fields: [outfitId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isFavorite])
  @@index([bodyImageId])
  @@index([outfitId])
  @@map("tryon_results")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED

  @@map("job_status")
}

enum JobType {
  TRYON_GENERATION
  POSE_ESTIMATION
  BACKGROUND_REMOVAL
  IMAGE_PROCESSING
  GARMENT_SEGMENTATION
  MODEL_3D_GENERATION
  RECOMMENDATION_GENERATION

  @@map("job_type")
}

model ProcessingJob {
  id      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String?   @map("user_id") @db.Uuid
  jobType JobType   @map("job_type")
  status  JobStatus @default(QUEUED)

  inputData    Json  @map("input_data")
  resultData   Json? @map("result_data")
  errorMessage String? @map("error_message") @db.Text
  retryCount   Int     @default(0) @map("retry_count") @db.Integer
  maxRetries   Int     @default(3) @map("max_retries") @db.Integer

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamp
  startedAt   DateTime? @map("started_at") @db.Timestamp
  completedAt DateTime? @map("completed_at") @db.Timestamp
  priority    Int       @default(0) @db.Integer

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId, status])
  @@index([jobType, status])
  @@index([priority, createdAt])
  @@map("processing_jobs")
}

model RecommendationLog {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId  String  @map("user_id") @db.Uuid
  eventId String? @map("event_id") @db.Uuid

  recommendedOutfitIds  Json   @default("[]") @map("recommended_outfit_ids")
  recommendedGarmentIds Json   @default("[]") @map("recommended_garment_ids")
  algorithmVersion      String @map("algorithm_version") @db.VarChar(50)
  algorithmParams       Json?  @map("algorithm_params")
  userFeedback          Json?  @map("user_feedback")
  feedbackScore         Float? @map("feedback_score") @db.Real

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event? @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([eventId])
  @@map("recommendation_logs")
}

model SystemMetric {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(100)
  metricValue Float    @map("metric_value") @db.Real
  metricUnit  String?  @map("metric_unit") @db.VarChar(50)
  tags        Json?    @default("{}")
  timestamp   DateTime @default(now()) @db.Timestamp

  @@index([metricName, timestamp(sort: Desc)])
  @@index([timestamp])
  @@map("system_metrics")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String   @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  changes    Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  timestamp  DateTime @default(now()) @db.Timestamp

  @@index([userId, timestamp(sort: Desc)])
  @@index([entityType, entityId])
  @@index([action, timestamp(sort: Desc)])
  @@map("audit_logs")
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED

  @@map("moderation_status")
}

model ContentModeration {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType String           @map("entity_type") @db.VarChar(50)
  entityId   String           @map("entity_id") @db.Uuid
  imageUrl   String           @map("image_url") @db.Text
  status     ModerationStatus @default(PENDING)

  @@map("content_moderation")
}

enum SearchStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED

  @@map("search_status")
}

model DressSearch {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String?      @map("user_id") @db.Uuid
  prompt       String       @db.Text
  geo          String       @db.VarChar(255)
  parsedParams Json?        @map("parsed_params")
  taskId       String       @unique @map("task_id") @db.VarChar(255)
  status       SearchStatus @default(PENDING)
  errorMessage String?      @map("error_message") @db.Text
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamp

  products DressProduct[]
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@index([taskId])
  @@map("dress_searches")
}

model DressProduct {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  searchId    String   @map("search_id") @db.Uuid
  productName String   @map("product_name") @db.VarChar(500)
  price       String?  @db.VarChar(100)
  imageUrl    String?  @map("image_url") @db.Text
  productUrl  String   @map("product_url") @db.Text
  description String?  @db.Text
  brand       String?  @db.VarChar(255)
  availability String? @db.VarChar(100)
  rawMetadata Json?    @map("raw_metadata")
  source      String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  search DressSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)

  @@index([searchId])
  @@map("dress_products")
}

// ── AI-server specific models ────────────────────────────────────────────────

model GenerationJob {
  id                String    @id @default(cuid())
  /// FK to users.id — must be @db.Uuid to match the PK type on User
  userId            String    @db.Uuid
  jobType           String
  status            String    @default("PENDING")
  progress          Int       @default(0)
  currentStage      String?
  tripoTaskId       String?
  inputS3Key        String?
  outputGlbS3Key    String?
  outputGlbRedisKey String?
  templateDressId   String?
  userImageS3Key    String?
  glbSource         String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  completedAt       DateTime?

  /// Enforced FK — prevents orphaned job rows and enables Prisma relation queries
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status])
  @@map("generation_jobs")
}

model ConsentRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  consentType String   @map("consent_type") @db.VarChar(50)
  granted     Boolean
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade, map: "consent_user_fkey")
  userProfile UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade, map: "consent_profile_fkey")

  @@index([userId, createdAt(sort: Desc)])
  @@map("consent_records")
}

model UserProfile {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @unique @map("user_id") @db.Uuid
  measHeight    Float?    @map("meas_height")
  measChest     Float?    @map("meas_chest")
  measWaist     Float?    @map("meas_waist")
  measHips      Float?    @map("meas_hips")
  measShoulders Float?    @map("meas_shoulders")
  tHeight       Float?    @map("t_height")
  tFullness     Float?    @map("t_fullness")
  bodyLabel     String?   @map("body_label") @db.VarChar(50)
  ethnicity     String?   @db.VarChar(100)
  gender        String?   @db.VarChar(50)
  location      String?   @db.VarChar(255)
  preferences   Json?
  consentGiven  Boolean   @default(false) @map("consent_given")
  consentAt     DateTime? @map("consent_at") @db.Timestamp
  deletedAt     DateTime? @map("deleted_at") @db.Timestamp
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamp

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentRecords ConsentRecord[]

  @@index([userId])
  @@map("user_profiles")
}

model DressTemplate {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  category     String   @db.VarChar(50)
  ethnicity    String?  @db.VarChar(100)
  bodyLabel    String?  @map("body_label") @db.VarChar(50)
  /// Canonical GLB source URI (s3:bucket/key, url:https://..., local:/path).
  /// This is the single source of truth — glbS3Key is kept for migration
  /// compatibility only and will be removed in a future migration.
  glbSource    String?  @map("glb_source") @db.Text
  /// @deprecated — use glbSource. Kept so existing rows remain readable
  /// until a data migration populates glbSource from glbS3Key.
  glbS3Key     String?  @map("glb_s3_key") @db.Text
  thumbnailUrl String?  @map("thumbnail_url") @db.Text
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp

  @@index([category, isActive])
  @@index([ethnicity, bodyLabel, isActive])
  @@map("dress_templates")
}
