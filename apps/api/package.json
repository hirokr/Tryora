	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"cross-env": "^10.1.0",
		"eslint": "^10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
