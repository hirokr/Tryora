generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// TODO: FIX THE SCHEMA 
model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  name               String
  password           String
  hashedRefreshToken String?
  profiles           Profile?
}

model Profile {
  id     String @id @default(uuid())
  bio    String
  avater String
  
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}
